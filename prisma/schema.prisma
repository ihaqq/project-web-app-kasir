generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// --- Enum untuk Inventory Logs ---
enum LogType {
  MASUK
  KELUAR
  ADJUSTMENT
}

// --- Tabel Users ---
model User {
  id         String     @id @default(uuid())
  username   String     @unique
  email      String     @unique
  password   String
  isApprove  Boolean    @default(false) @map("is_approve")
  role       String
  purchases  Purchase[]
  sales      Sale[]

  @@map("users")
}

// --- Tabel Vendors ---
model Vendor {
  id           String     @id @default(uuid())
  namaVendor   String     @map("nama_vendor")
  kontakVendor String?    @map("kontak_vendor")
  products     Product[]
  purchases    Purchase[]

  @@map("vendors")
}

// --- Tabel Kategori Produk ---
model KategoriProduk {
  id           String    @id @default(uuid())
  namaKategori String    @map("nama_kategori")
  products     Product[]

  @@map("kategori_produks")
}

// --- Tabel Satuan Unit ---
model SatuanUnit {
  id           String        @id @default(uuid())
  namaSatuan   String        @map("nama_satuan")
  productUnits ProductUnit[]

  @@map("satuan_unit")
}

// --- Tabel Products ---
model Product {
  id            String         @id @default(uuid())
  vendorId      String         @map("vendor_id")
  categoryId    String         @map("category_id")
  name          String
  minStock      Int            @map("min_stock")
  
  vendor        Vendor         @relation(fields: [vendorId], references: [id])
  category      KategoriProduk @relation(fields: [categoryId], references: [id])
  
  productUnits  ProductUnit[]
  inventory     Inventory?
  inventoryLogs InventoryLog[]

  @@map("products")
}

// --- Tabel Product Unit ---
model ProductUnit {
  id             String           @id @default(uuid())
  productId      String           @map("product_id")
  satuanUnitId   String           @map("satuan_unit_id")
  barcode        String           @unique
  conversionQty  Int              @map("conversion_qty")
  hargaJual      Decimal          @map("harga_jual") @db.Decimal(10, 2)
  hargaBeli      Decimal          @map("harga_beli") @db.Decimal(10, 2)
  isBaseUnit     Boolean          @default(false) @map("is_base_unit")

  product        Product          @relation(fields: [productId], references: [id])
  satuanUnit     SatuanUnit       @relation(fields: [satuanUnitId], references: [id])
  
  purchaseDetails PurchaseDetail[]
  saleDetails     SaleDetail[]

  @@map("product_unit")
}

// --- Tabel Inventory ---
model Inventory {
  productId   String   @id @map("product_id")
  totalQty    Int      @default(0) @map("total_qty")
  lastUpdated DateTime @updatedAt @map("last_updated")

  product     Product  @relation(fields: [productId], references: [id])

  @@map("inventory")
}

// --- Tabel Inventory Logs ---
model InventoryLog {
  id          String   @id @default(uuid())
  productId   String   @map("product_id")
  type        LogType
  quantity    Int
  referenceId String?  @map("reference_id")
  notes       String?  @db.Text

  product     Product  @relation(fields: [productId], references: [id])

  @@map("inventory_logs")
}

// --- Tabel Purchase ---
model Purchase {
  id          String           @id @default(uuid())
  vendorId    String           @map("vendor_id")
  userId      String           @map("user_id")
  noFaktur    String?          @map("no_faktur")
  totalCost   Decimal          @map("total_cost") @db.Decimal(10, 2)
  createdAt   DateTime         @default(now()) @map("created_at")

  vendor      Vendor           @relation(fields: [vendorId], references: [id])
  user        User             @relation(fields: [userId], references: [id])
  details     PurchaseDetail[]

  @@map("purchase")
}

// --- Tabel Purchase Detail ---
model PurchaseDetail {
  id               String      @id @default(uuid())
  purchaseId       String      @map("purchase_id")
  productUnitId    String      @map("product_unit_id")
  quantity         Int
  hargaBeliSaatIni Decimal     @map("harga_beli_saat_ini") @db.Decimal(10, 2)
  subtotal         Decimal     @db.Decimal(10, 2)

  purchase         Purchase    @relation(fields: [purchaseId], references: [id])
  productUnit      ProductUnit @relation(fields: [productUnitId], references: [id])

  @@map("purchase_detail")
}

// --- Tabel Sales ---
model Sale {
  id         String       @id @default(uuid())
  userId     String       @map("user_id")
  totalPrice Decimal      @map("total_price") @db.Decimal(10, 2)
  createdAt  DateTime     @default(now()) @map("created_at")

  user       User         @relation(fields: [userId], references: [id])
  details    SaleDetail[]

  @@map("sales")
}

// --- Tabel Sale Details ---
model SaleDetail {
  id            String      @id @default(uuid())
  saleId        String      @map("sale_id")
  productUnitId String      @map("product_unit_id")
  quantity      Int
  subtotal      Decimal     @db.Decimal(10, 2)

  sale          Sale        @relation(fields: [saleId], references: [id])
  productUnit   ProductUnit @relation(fields: [productUnitId], references: [id])

  @@map("sale_details")
}